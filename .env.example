# OpenCode Go / AI SDK
OPENCODE_GO_BASE_URL=http://localhost:11434/v1
OPENCODE_GO_API_KEY=replace-me
OPENCODE_GO_MODEL=opencode-go

# OpenAI API key for embeddings
OPENAI_API_KEY=replace-me

# SQLite database file used by the app and Drizzle
DATABASE_URL=./sqlite.db

# LanceDB directory for embeddings and RAG search
VECTOR_DB_PATH=./lancedb

# Web server port
PORT=3000

# Cron timezone for scheduled sync jobs
CRON_TIMEZONE=Asia/Tokyo

# Logging output directory and level
LOG_DIR=./logs
LOG_LEVEL=info

# Optional vector dimension override if your embedding model differs
VECTOR_DIMENSION=1536
