{
  "name": "rss-reader",
  "version": "1.0.0",
  "private": true,
  "description": "Ideal RSS reader scaffold",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "npm run build:client && tsc -p tsconfig.json",
    "build:client": "vite build && tsc -p tsconfig.client.json --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hexx/rss-reader.git"
  },
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/hexx/rss-reader/issues"
  },
  "homepage": "https://github.com/hexx/rss-reader#readme",
  "dependencies": {
    "@ai-sdk/openai": "^4.0.0",
    "@ai-sdk/openai-compatible": "^3.0.0",
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4.3.0",
    "ai": "^7.0.0",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^15.0.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rss-parser": "^3.13.0",
    "shadcn": "^4.11.0",
    "sql.js": "^1.13.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260515.1",
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.0",
    "drizzle-kit": "^0.31.10",
    "msw": "^2.14.5",
    "oxlint": "^1.68.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.5",
    "wrangler": "^4.91.0"
  }
}
