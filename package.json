{
  "name": "rss-reader",
  "version": "1.0.0",
  "private": true,
  "description": "Ideal RSS reader scaffold",
  "type": "module",
  "engines": {
    "node": ">=24 <26"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "cli": "tsx src/cli.ts",
    "serve": "tsx src/server/index.ts",
    "cron": "tsx src/cron.ts",
    "start:all": "concurrently -n server,cron -c cyan,magenta --kill-others-on-fail \"npm run serve\" \"npm run cron\"",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hexx/rss-reader.git"
  },
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/hexx/rss-reader/issues"
  },
  "homepage": "https://github.com/hexx/rss-reader#readme",
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.47",
    "@lancedb/lancedb": "^0.27.2",
    "ai": "^6.0.177",
    "apache-arrow": "^18.1.0",
    "better-sqlite3": "^12.9.0",
    "cheerio": "^1.2.0",
    "commander": "^14.0.3",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "node-cron": "^4.2.1",
    "rss-parser": "^3.13.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.2",
    "drizzle-kit": "^0.31.10",
    "msw": "^2.14.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
